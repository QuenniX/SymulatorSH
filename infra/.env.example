# =====================================================
# PRZYKLADOWE ZMIENNE SRODOWISKOWE - PRODUKCJA
# =====================================================
# Skopiuj jako .env i wypelnij faktycznymi wartosciami z Neon i InfluxDB Cloud:
#
#   cp infra/.env.example infra/.env
#   nano infra/.env
#
# UWAGA: .env jest w .gitignore - NIE commituj go do gita!
# =====================================================

# =====================================================
# PostgreSQL - Neon Cloud
# =====================================================
# Connection string z Neon Dashboard - rozbij na trzy czesci:
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# Forma JDBC: jdbc:postgresql://HOST/DB?sslmode=require

POSTGRES_URL=jdbc:postgresql://ep-cold-bird-a26c5u2v.eu-central-1.aws.neon.tech/neondb?sslmode=require
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=wpisz_haslo_z_neon

# =====================================================
# InfluxDB Cloud - time-series database
# =====================================================
INFLUX_URL=https://eu-central-1-1.aws.cloud2.influxdata.com
INFLUX_ORG=SmartHome
INFLUX_BUCKET=measurements
INFLUX_TOKEN=wpisz_token_z_influx_cloud
